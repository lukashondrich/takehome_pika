# Required: Discord bot token from the developer portal.
DISCORD_BOT_TOKEN=your-bot-token-here

# Required: numeric Discord user ID for the one owner allowed to DM the bot.
OWNER_DISCORD_ID=your-numeric-discord-user-id

# Required: Anthropic API key used by the bot and eval scenarios.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables Tavily-backed web_search.
TAVILY_API_KEY=

# Optional: enables update_avatar via OpenAI image generation.
OPENAI_API_KEY=

# Optional: start from seed/ and clear model-written state.
BOT_RESET_STATE=0

# Optional: username to restore when BOT_RESET_STATE=1.
BOT_DEFAULT_USERNAME=

# Optional: override local state/log locations.
# On Railway, an attached volume's RAILWAY_VOLUME_MOUNT_PATH is used automatically.
BOT_DATA_DIR=
BOT_LOGS_DIR=
